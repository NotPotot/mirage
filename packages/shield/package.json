{
  "name": "@mirageshield/mirage",
  "version": "0.2.0",
  "description": "AI breach defense package - protect any website from AI-driven attacks. Works in Node.js, Next.js, Express, React, and any static HTML page via CDN.",
  "keywords": [
    "security",
    "bot-detection",
    "anti-scraping",
    "ai-defense",
    "honeypot",
    "headless-detection",
    "rate-limiting",
    "nextjs",
    "express",
    "react",
    "browser",
    "cdn"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "browser": "./dist/browser.mjs",
  "unpkg": "./dist/client.global.js",
  "jsdelivr": "./dist/client.global.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "./dist/client.global.js",
    "./dist/browser.mjs"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/browser.mjs",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./nextjs": {
      "types": "./dist/nextjs.d.ts",
      "import": "./dist/nextjs.mjs",
      "require": "./dist/nextjs.js",
      "default": "./dist/nextjs.mjs"
    },
    "./express": {
      "types": "./dist/express.d.ts",
      "import": "./dist/express.mjs",
      "require": "./dist/express.js",
      "default": "./dist/express.mjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.mjs",
      "require": "./dist/react.js",
      "default": "./dist/react.mjs"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.mjs",
      "default": "./dist/browser.mjs"
    },
    "./client": "./dist/client.global.js",
    "./dist/*": "./dist/*",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsup",
    "dev": "tsup --watch",
    "test": "echo \"no tests yet\"",
    "setup": "node ./bin/init.mjs",
    "postinstall": "node -e \"try{require('fs').existsSync(require('path').join(process.cwd(),'package.json'))&&console.log('\\n  [@mirageshield/mirage] Run \\x1b[1mnpx mirage\\x1b[0m to configure Mirage Shield\\n')}catch(e){}\""
  },
  "peerDependencies": {
    "next": ">=14",
    "express": ">=4",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "next": { "optional": true },
    "express": { "optional": true },
    "react": { "optional": true }
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "@types/react": "^19.0.0",
    "@types/express": "^5.0.0"
  },
  "bin": {
    "mirage": "./bin/init.mjs"
  },
  "files": ["dist", "bin"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NotPotot/cipherhacks.git",
    "directory": "packages/shield"
  },
  "homepage": "https://github.com/NotPotot/cipherhacks#readme",
  "bugs": {
    "url": "https://github.com/NotPotot/cipherhacks/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
